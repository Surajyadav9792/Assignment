MONGO_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database_name>"
JWT_SECRET=your_jwt_secret_here

# How long tokens are valid. 24h is sane for a demo; production might be shorter.
JWT_EXPIRES_IN=24h


# Example production: https://forgeflow.vercel.app
FRONTEND_ORIGIN=http://localhost:5173

# Express runtime mode. Use "production" on Vercel.
NODE_ENV=development

# Winston log verbosity: error | warn | info | debug
LOG_LEVEL=info

# Port the Express server binds to in local dev (ignored on Vercel — serverless).
PORT=5000

# -----------------------------------------------------------------------------
# Frontend (Vite) — prefixed with VITE_
# -----------------------------------------------------------------------------
# Base URL the React SPA uses to call the API.
# - Local dev:        http://localhost:5000/api/v1
# - Vercel (default): leave UNSET → frontend defaults to /api/v1 (same origin)
# Only set this on Vercel if your backend lives on a different domain.
# VITE_API_BASE_URL=

# Brand name shown in places like the document title.
VITE_APP_NAME=ForgeFlow
